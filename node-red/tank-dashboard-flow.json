  {
    "id": "alert-guard",
    "type": "function",
    "z": "thermal-tab",
    "name": "Alert guard",
    "func": "// Emit an alert only when level leaves the band AND confidence is high AND state changes.\nconst LOW = 20;\nconst HIGH = 90;\nconst COOLDOWN_MS = 60_000;\n\nconst t = msg._tank || {};\nif (t.confidence !== 'high') return null;\n\nconst id = t.id || msg.topic;\nconst state = t.level_pct < LOW ? 'LOW' : (t.level_pct > HIGH ? 'HIGH' : 'OK');\n\nconst mem = context.get('mem') || {};\nconst prev = mem[id] || { state: 'OK', ts: 0 };\nconst now = Date.now();\n\nconst isOut = state !== 'OK';\nconst transitioned = state !== prev.state;\nconst stale = isOut && (now - prev.ts) > COOLDOWN_MS;\n\nmem[id] = { state, ts: (isOut && (transitioned || stale)) ? now : prev.ts };\ncontext.set('mem', mem);\n\nlet out = null;\nif (!isOut) {\n    if (prev.state !== 'OK') {\n        out = {\n            topic: 'Tank recovered',\n            payload: (t.name || id) + ' back in band (' + t.level_pct.toFixed(1) + '%)',\n            _tank: t,\n            _state: 'OK'\n        };\n    }\n} else if (transitioned || stale) {\n    out = {\n        topic: 'Tank ' + state,\n        payload: (t.name || id) + ' level ' + t.level_pct.toFixed(1) + '% (' + state + ')',\n        _tank: t,\n        _state: state\n    };\n}\n\nif (out) {\n    // Persist into bounded history\n    const hist = flow.get('alerts') || [];\n    hist.push({ ts: now, state: out._state, payload: out.payload, topic: out.topic });\n    if (hist.length > 200) hist.splice(0, hist.length - 200);\n    flow.set('alerts', hist);\n    out.payload_history = hist;\n}\nreturn out;",
    "outputs": 1,
    "x": 370,
    "y": 400,
    "wires": [["toast-alert", "tpl-alerts", "debug-alert"]]
  },
  {
    "id": "toast-alert",
    "type": "ui_toast",
    "z": "thermal-tab",
    "position": "top right",
    "displayTime": "6",
    "highlight": "#ef4444",
    "sendall": true,
    "outputs": 0,
    "ok": "OK",
    "cancel": "",
    "raw": false,
    "className": "",
    "topic": "",
    "name": "Alert toast",
    "x": 600,
    "y": 360,
    "wires": []
  },
  {
    "id": "debug-alert",
    "type": "debug",
    "z": "thermal-tab",
    "name": "Alert debug",
    "active": true,
    "tosidebar": true,
    "console": false,
    "tostatus": true,
    "complete": "payload",
    "targetType": "msg",
    "statusVal": "payload",
    "statusType": "msg",
