  {
    "id": "cfg-init",
    "type": "function",
    "z": "thermal-tab",
    "name": "Init thermal base",
    "func": "// Node-RED runs in Docker (bridge net) and CANNOT reach the host's 127.0.0.1:8080.\n// Default to the publicly-exposed CF subdomain for this Nucleus (N-1065).\n// Override via env THERMAL_API if you deploy elsewhere or run Node-RED on host network\n// (then use http://127.0.0.1:8080 or http://host.docker.internal:8080).\nconst base = env.get('THERMAL_API') || 'https://p8080-n-1065-d.datadesng.com';\nflow.set('thermal_base', base);\nflow.set('alerts', flow.get('alerts') || []);\nflow.set('tank_overrides', flow.get('tank_overrides') || {});\nnode.status({ fill: 'green', shape: 'dot', text: base });\nreturn null;",
    "outputs": 1,
    "x": 330,
    "y": 40,
    "wires": [
      []
    ]
  },
  {
    "id": "http-ingest",
    "type": "http in",
    "z": "thermal-tab",
    "name": "POST /thermal/ingest",
    "url": "/thermal/ingest",
    "method": "post",
    "upload": false,
    "swaggerDoc": "",
    "x": 140,
    "y": 120,
    "wires": [
      [
        "ingest-process"
      ]
    ]
  },
  {
    "id": "http-response",
    "type": "http response",
    "z": "thermal-tab",
    "name": "",
    "statusCode": "",
    "headers": {},
    "x": 700,
    "y": 80,
    "wires": []
  },
  {
    "id": "ingest-process",
    "type": "function",
    "z": "thermal-tab",
    "name": "Process ingest",
    "func": "const p = msg.payload;\nif (!p || !Array.isArray(p.tanks)) {\n    msg.statusCode = 400;\n    msg.payload = { error: 'expected {ts, site_id, tanks:[...]}' };\n    return [null, null, null, null, msg, null, null];\n}\n\n// publisher.py v0.4+ ALWAYS sends `ts` as epoch-ms (int). No unit math.\nconst ts = typeof p.ts === 'number' ? p.ts : Date.now();\np.ts = ts;\n\n// Apply per-tank user overrides (rename + medium). Preserve original\n// auto-detected values so the config panel can show them as placeholders.\nconst overrides = flow.get('tank_overrides') || {};\nfor (const t of p.tanks) {\n    if (t.auto_name === undefined) t.auto_name = t.name || t.id;\n    if (t.auto_medium === undefined) t.auto_medium = t.medium || 'unknown';\n    const ov = overrides[t.id];\n    if (ov) {\n        if (ov.name) t.name = ov.name;\n        if (ov.medium && ov.medium !== 'auto') {\n            t.medium = ov.medium;\n            t.medium_confidence = 1.0;\n        }\n    }\n}\n\nflow.set('latest', p);\nflow.set('latest_ts', ts);\n\n// Fan-out:\n//   [0] tank-cards + tank-config -> full payload (+ overrides)\n//   [1] chart-level              -> {topic,name, payload:level_pct} per tank, high-conf only\n//   [2] chart-temp               -> {topic, payload:temp_avg} per tank, always\n//   [3] alerts                   -> each tank for alert-guard\n//   [4] http response\n//   [5] events summary\n//   [6] overview header (site_id + calibration status)\nconst charts = [];\nconst temps  = [];\nconst alerts = [];\nfor (const t of p.tanks) {\n    const topic = t.name || t.id;\n    if (t.confidence === 'high' && typeof t.level_pct === 'number') {\n        charts.push({ topic, payload: t.level_pct });\n    }\n    if (typeof t.temp_avg === 'number') {\n        temps.push({ topic, payload: t.temp_avg });\n    }\n    alerts.push({ topic, payload: t.level_pct, _tank: t });\n}\n\nconst cards = { payload: Object.assign({}, p, { overrides }) };\nconst header = {\n    payload: {\n        site_id: p.site_id || 'unknown',\n        ts,\n        n: p.tanks.length,\n        calibration: (p.tanks[0] && p.tanks[0].calibration) || null\n    }\n};\nconst summary = {\n    payload: {\n        n: p.tanks.length,\n        ts: new Date(ts).toISOString().replace('T',' ').slice(0,19) + 'Z'\n    }\n};\n\nmsg.statusCode = 200;\nmsg.payload = { ok: true, n: p.tanks.length };\nreturn [cards, charts, temps, alerts, msg, summary, header];",
    "outputs": 7,
    "x": 370,
    "y": 120,
    "wires": [
      [
        "tpl-tank-cards",
        "tpl-tank-config"
      ],
      [
        "chart-level"
      ],
      [
        "chart-temp"
      ],
      [
        "alert-guard"
      ],
      [
        "http-response"
      ],
      [
        "events-text"
      ],
      [
        "tpl-overview"
      ]
    ]
  },
  {
    "id": "tpl-overview",
    "type": "ui_template",
    "z": "thermal-tab",
    "group": "dash-group-overview",
    "name": "Site header",
    "order": 1,
    "width": 24,
    "height": 3,
    "format": "<style>\n.ov{display:flex;align-items:center;gap:14px;padding:10px 14px;color:#e6e6e6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;height:100%;background:linear-gradient(135deg,#121821 0%,#1a222d 100%);border-radius:12px;border:1px solid #2a3240;box-sizing:border-box}\n.ov .site{display:flex;flex-direction:column;min-width:0;padding-right:14px;border-right:1px solid #2a3240;flex:0 0 auto}\n.ov .site .t1{font-size:17px;font-weight:700;letter-spacing:-0.02em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:240px}\n.ov .site .t2{font-size:10px;color:#64748b;font-family:monospace;text-transform:uppercase;letter-spacing:.08em;margin-top:3px}\n.ov .kpis{display:flex;gap:10px;flex:1 1 auto;min-width:0;overflow:hidden}\n.ov .kpi{background:#0f1419;border:1px solid #1f2937;border-radius:10px;padding:7px 14px;display:flex;flex-direction:column;gap:1px;min-width:72px}\n.ov .kpi .v{font-size:20px;font-weight:700;letter-spacing:-0.02em;line-height:1.1;font-variant-numeric:tabular-nums;color:#e6e6e6}\n.ov .kpi .l{font-size:9px;color:#64748b;text-transform:uppercase;letter-spacing:.1em;font-weight:700}\n.ov .kpi.oil{border-color:#3b1d09}.ov .kpi.oil .v{color:#fb923c}\n.ov .kpi.water{border-color:#082f49}.ov .kpi.water .v{color:#38bdf8}\n.ov .kpi.alert{border-color:#3f1d1d}.ov .kpi.alert .v{color:#fca5a5}\n.ov .kpi.avg .v{color:#4ade80}\n.ov .r{display:flex;align-items:center;gap:8px;margin-left:auto;flex:0 0 auto}\n.ov .chips{display:flex;gap:5px}\n.ov .chip{font-size:9px;padding:3px 8px;border-radius:8px;letter-spacing:.06em;text-transform:uppercase;font-weight:700}\n.ov .chip.ok{background:#052e16;color:#4ade80}\n.ov .chip.warn{background:#2a1f00;color:#fbbf24}\n.ov .chip.bad{background:#3f1d1d;color:#fca5a5}\n.ov .chip.n{background:#1e293b;color:#94a3b8}\n.ov a.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 12px;border-radius:8px;background:#2563eb;color:#fff;text-decoration:none;font-size:12px;font-weight:600;white-space:nowrap;box-shadow:0 2px 8px rgba(37,99,235,0.3)}\n.ov a.btn:hover{background:#1d4ed8}\n</style>\n<div class=\"ov\" ng-init=\"tanks = (msg.payload && msg.payload.tanks) || []\">\n  <div class=\"site\">\n    <div class=\"t1\">{{msg.payload.site_id || 'Supervisor'}}</div>\n    <div class=\"t2\">{{msg.payload.ts ? (msg.payload.ts | date:'yyyy-MM-dd HH:mm:ss') : '--:--:--'}}</div>\n  </div>\n  <div class=\"kpis\">\n    <div class=\"kpi\"><div class=\"v\">{{tanks.length}}</div><div class=\"l\">Tanks</div></div>\n    <div class=\"kpi oil\"><div class=\"v\">{{(tanks | filter:{medium:'oil'}).length}}</div><div class=\"l\">Oil</div></div>\n    <div class=\"kpi water\"><div class=\"v\">{{(tanks | filter:{medium:'water'}).length}}</div><div class=\"l\">Water</div></div>\n    <div class=\"kpi alert\"><div class=\"v\">{{countAlerts(tanks)}}</div><div class=\"l\">Alerts</div></div>\n    <div class=\"kpi avg\"><div class=\"v\">{{tanks.length ? (avgLevel(tanks)/tanks.length | number:0) : '--'}}%</div><div class=\"l\">Avg Level</div></div>\n  </div>\n  <div class=\"r\">\n    <div class=\"chips\">\n      <span class=\"chip\" ng-class=\"{ ok: fresh, warn: !fresh && msg.payload.ts, bad: !msg.payload.ts }\" ng-init=\"fresh = (msg.payload.ts && (Date.now() - msg.payload.ts) < 30000)\">{{fresh ? 'live' : (msg.payload.ts ? 'stale' : 'offline')}}</span>\n      <span class=\"chip\" ng-class=\"{ ok: msg.payload.calibration && msg.payload.calibration.calibrated_at, n: !msg.payload.calibration || !msg.payload.calibration.calibrated_at }\">{{msg.payload.calibration && msg.payload.calibration.calibrated_at ? 'cal' : 'uncal'}}</span>\n    </div>\n    <a class=\"btn\" id=\"op-link\" href=\"#\" target=\"_blank\" rel=\"noopener\">Operator ↗</a>\n  </div>\n</div>\n<script>\n(function(){\n  function apply(){\n    var a = document.getElementById('op-link');\n    if (!a) return setTimeout(apply, 100);\n    var h = location.hostname;\n    var m = h.match(/^p1880-(n-[a-z0-9-]+)-(.*)$/i);\n    a.href = m ? (location.protocol + '//p8080-' + m[1] + '-' + m[2] + '/') : (location.protocol + '//' + h + ':8080/');\n  }\n  setTimeout(apply, 0);\n})();\n</script>\n<script>\n(function(){\n  function wait(cb){ var t = document.querySelector('.ov'); if (!t) return setTimeout(function(){wait(cb);}, 100); var s = angular.element(t).scope(); if (!s) return setTimeout(function(){wait(cb);}, 100); cb(s); }\n  wait(function(scope){\n    scope.countAlerts = function(ts){ if(!ts) return 0; var n=0; for (var i=0;i<ts.length;i++){ var p=ts[i].level_pct; if (p===undefined||p===null) continue; if (p<20||p>90) n++; } return n; };\n    scope.avgLevel = function(ts){ if(!ts||!ts.length) return 0; var s=0,c=0; for (var i=0;i<ts.length;i++){ var p=ts[i].level_pct; if (p===undefined||p===null) continue; s+=p; c++; } return c?s/c:0; };\n    scope.$applyAsync();\n  });\n})();\n</script>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "x": 640,
    "y": 120,
    "wires": [
      []
    ]
