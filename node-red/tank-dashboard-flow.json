  {
    "id": "tpl-alerts",
    "type": "ui_template",
    "z": "thermal-tab",
    "group": "dash-group-alerts",
    "name": "Alert feed",
    "order": 1,
    "width": 12,
    "height": 5,
    "format": "<style>\n.al{height:100%;overflow-y:auto;padding:6px;font-family:monospace;font-size:12px;color:#e6e6e6}\n.al .row{display:grid;grid-template-columns:88px 70px 1fr;gap:10px;padding:6px 8px;border-bottom:1px solid #1f2937;align-items:center}\n.al .ts{color:#6b7280}\n.al .tag{padding:2px 8px;border-radius:10px;text-align:center;font-weight:700;font-size:10px;letter-spacing:.04em}\n.al .tag.LOW{background:#2a1f00;color:#fbbf24}\n.al .tag.HIGH{background:#3f1d1d;color:#fca5a5}\n.al .tag.OK{background:#052e16;color:#4ade80}\n.al .msg{color:#cbd5e1}\n.al .empty{color:#64748b;text-align:center;padding:14px;font-family:sans-serif}\n</style>\n<div class=\"al\">\n  <div class=\"row\" ng-repeat=\"a in alerts | orderBy:'-ts' | limitTo: 40 track by $index\">\n    <span class=\"ts\">{{a.ts | date:'HH:mm:ss'}}</span>\n    <span class=\"tag\" ng-class=\"a.state\">{{a.state}}</span>\n    <span class=\"msg\">{{a.payload}}</span>\n  </div>\n  <div class=\"empty\" ng-if=\"!alerts || !alerts.length\">no alerts yet \u2014 thresholds are 20% / 90%</div>\n</div>\n<script>\n(function(scope){\n  scope.alerts = scope.alerts || [];\n  scope.$watch('msg', function(m){\n    if (!m) return;\n    if (Array.isArray(m.payload_history)) {\n      // alert-guard sent the canonical history alongside the event\n      scope.alerts = m.payload_history.slice();\n    } else if (m.payload) {\n      scope.alerts.push({ ts: Date.now(), state: m._state || 'OK', payload: m.payload });\n      if (scope.alerts.length > 200) scope.alerts.splice(0, scope.alerts.length - 200);\n    }\n  });\n})(scope);\n</script>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "x": 600,
    "y": 560,
    "wires": [[]]
  },

