  {
    "id": "tpl-tank-config",
    "type": "ui_template",
    "z": "thermal-tab",
    "group": "dash-group-config",
    "name": "Tank rename + medium override",
    "order": 1,
    "width": 24,
    "height": 8,
    "format": "<style>\n.tcfg{padding:12px;color:#e6e6e6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}\n.tcfg-hdr{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;gap:10px;flex-wrap:wrap}\n.tcfg-hdr .t{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8}\n.tcfg-hdr .h{font-size:11px;color:#6b7280;font-family:monospace}\n.tcfg table{width:100%;border-collapse:collapse;font-size:12px;table-layout:fixed}\n.tcfg th{text-align:left;padding:6px 8px;font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:#6b7280;font-weight:700;border-bottom:1px solid #1f2937}\n.tcfg th.sid{width:110px}\n.tcfg th.sauto{width:32%}\n.tcfg th.sm{width:110px}\n.tcfg td{padding:6px 8px;border-bottom:1px solid #1a1f28;vertical-align:middle}\n.tcfg td.id{font-family:monospace;color:#9aa4b2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n.tcfg td.auto{font-size:11px;color:#64748b;font-family:monospace;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n.tcfg td.auto .med{display:inline-block;padding:1px 6px;border-radius:10px;margin-left:6px;font-size:9px;text-transform:uppercase;letter-spacing:.05em;background:#1e293b;color:#94a3b8}\n.tcfg td.auto .med.water{background:#082f49;color:#38bdf8}\n.tcfg td.auto .med.oil{background:#3b1d09;color:#fb923c}\n.tcfg input, .tcfg select{background:#0f1419;color:#e6e6e6;border:1px solid #2a3240;border-radius:6px;padding:6px 8px;font-size:12px;width:100%;font-family:inherit;box-sizing:border-box}\n.tcfg input:focus, .tcfg select:focus{outline:none;border-color:#2563eb;box-shadow:0 0 0 2px rgba(37,99,235,0.2)}\n.tcfg input::placeholder{color:#475569}\n.tcfg .actions{display:flex;justify-content:flex-end;align-items:center;gap:10px;padding-top:12px;margin-top:10px;border-top:1px solid #1f2937}\n.tcfg button{background:#1e293b;color:#cbd5e1;border:1px solid #2a3240;border-radius:6px;padding:7px 14px;font-size:12px;cursor:pointer;font-weight:600;transition:background .15s;font-family:inherit}\n.tcfg button:hover{background:#2a3240;color:#fff}\n.tcfg button.primary{background:#2563eb;color:#fff;border-color:#2563eb}\n.tcfg button.primary:hover{background:#1d4ed8}\n.tcfg .st{font-size:11px;color:#4ade80;font-family:monospace;min-width:80px;text-align:right}\n.tcfg .hint{font-size:11px;color:#6b7280;text-align:center;padding:16px;font-family:monospace}\n</style>\n<div class=\"tcfg\">\n  <div class=\"tcfg-hdr\">\n    <span class=\"t\">Tank Configuration</span>\n    <span class=\"h\">rename + override medium — applies on next payload</span>\n  </div>\n  <table ng-if=\"rows.length\">\n    <thead>\n      <tr>\n        <th class=\"sid\">ID</th>\n        <th>Display name</th>\n        <th class=\"sm\">Medium</th>\n        <th class=\"sauto\">Auto-detected</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr ng-repeat=\"r in rows track by r.id\">\n        <td class=\"id\">{{r.id}}</td>\n        <td><input ng-model=\"r.name\" ng-attr-placeholder=\"{{r.auto_name}}\" maxlength=\"32\"/></td>\n        <td>\n          <select ng-model=\"r.medium\">\n            <option value=\"auto\">auto</option>\n            <option value=\"water\">water</option>\n            <option value=\"oil\">oil</option>\n          </select>\n        </td>\n        <td class=\"auto\">{{r.auto_name}}<span class=\"med\" ng-class=\"r.auto_medium\">{{r.auto_medium}}</span></td>\n      </tr>\n    </tbody>\n  </table>\n  <div class=\"hint\" ng-if=\"!rows.length\">no tanks detected yet — waiting for first payload from analyzer</div>\n  <div class=\"actions\">\n    <span class=\"st\">{{status}}</span>\n    <button ng-click=\"reset()\">Reset all</button>\n    <button class=\"primary\" ng-click=\"save()\">Save overrides</button>\n  </div>\n</div>\n<script>\n(function(scope){\n  scope.rows = scope.rows || [];\n  scope.status = '';\n  scope.$watch('msg', function(m){\n    if (!m || !m.payload || !Array.isArray(m.payload.tanks)) return;\n    var overrides = m.payload.overrides || {};\n    // preserve in-progress edits so a new payload doesn't clobber the user's typing\n    var edited = {};\n    scope.rows.forEach(function(r){ edited[r.id] = { name: r.name, medium: r.medium }; });\n    scope.rows = m.payload.tanks.map(function(t){\n      var ov = overrides[t.id] || {};\n      var e = edited[t.id];\n      return {\n        id: t.id,\n        name:   e ? e.name   : (ov.name   || ''),\n        medium: e ? e.medium : (ov.medium || 'auto'),\n        auto_name:   t.auto_name   || t.name || t.id,\n        auto_medium: t.auto_medium || t.medium || 'unknown'\n      };\n    });\n  });\n  scope.save = function(){\n    var out = {};\n    scope.rows.forEach(function(r){\n      var trimmed = (r.name || '').trim();\n      var hasMedium = r.medium && r.medium !== 'auto';\n      if (trimmed || hasMedium) {\n        out[r.id] = {};\n        if (trimmed)  out[r.id].name   = trimmed;\n        if (hasMedium) out[r.id].medium = r.medium;\n      }\n    });\n    scope.send({ topic: 'config-save', payload: out });\n    scope.status = 'saved ✓';\n    setTimeout(function(){ scope.status=''; try{scope.$apply();}catch(e){} }, 1800);\n  };\n  scope.reset = function(){\n    scope.rows.forEach(function(r){ r.name=''; r.medium='auto'; });\n    scope.send({ topic: 'config-save', payload: {} });\n    scope.status = 'reset ✓';\n    setTimeout(function(){ scope.status=''; try{scope.$apply();}catch(e){} }, 1800);\n  };\n})(scope);\n</script>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
