  {
    "id": "tpl-live-view",
    "type": "ui_template",
    "z": "thermal-tab",
    "group": "dash-group-live-view",
    "name": "Live thermal stream",
    "order": 1,
    "width": 14,
    "height": 9,
    "format": "<style>\n.lv{padding:6px;color:#e6e6e6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;height:100%;display:flex;flex-direction:column}\n.lv .hdr{display:flex;justify-content:space-between;align-items:center;padding:4px 8px;margin-bottom:6px;flex:0 0 auto}\n.lv .hdr .t{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8}\n.lv .hdr .tools{display:flex;gap:6px}\n.lv .hdr button{background:#1e293b;color:#cbd5e1;border:1px solid #2a3240;border-radius:6px;padding:5px 10px;font-size:11px;cursor:pointer;font-weight:600;transition:background .15s}\n.lv .hdr button:hover{background:#2a3240;color:#fff}\n.lv .wrap{position:relative;border-radius:12px;overflow:hidden;background:#000;border:1px solid #2a3240;flex:1 1 auto;display:flex;align-items:center;justify-content:center;min-height:260px}\n.lv .wrap img{width:100%;height:100%;display:block;object-fit:contain;max-height:100%}\n.lv .ph{color:#6b7280;font-family:monospace;font-size:12px;padding:30px;text-align:center}\n.lv .badge{position:absolute;top:10px;right:10px;padding:4px 10px;border-radius:10px;font-size:10px;text-transform:uppercase;letter-spacing:.06em;font-weight:700;background:rgba(15,20,25,0.75);color:#4ade80;border:1px solid rgba(74,222,128,0.3)}\n.lv .badge .pulse{display:inline-block;width:6px;height:6px;border-radius:50%;background:#4ade80;margin-right:5px;animation:lvp 1.2s ease-in-out infinite}\n.lv .badge.off{color:#f87171;border-color:rgba(248,113,113,0.3)}\n.lv .badge.off .pulse{background:#f87171;animation:none}\n@keyframes lvp{0%,100%{opacity:1}50%{opacity:0.35}}\n</style>\n<div class=\"lv\">\n  <div class=\"hdr\">\n    <span class=\"t\">Live Thermal Stream</span>\n    <div class=\"tools\">\n      <button id=\"lv-reload\" type=\"button\">Reload</button>\n    </div>\n  </div>\n  <div class=\"wrap\">\n    <div class=\"ph\" id=\"lv-ph\">connecting to thermal analyzer&hellip;</div>\n    <img id=\"lv-img\" alt=\"thermal stream\" style=\"display:none\"/>\n    <span class=\"badge\" id=\"lv-badge\"><span class=\"pulse\"></span>LIVE</span>\n  </div>\n</div>\n<script>\n(function(){\n  function deriveBase(){\n    var h = location.hostname;\n    var m = h.match(/^p1880-(n-[a-z0-9-]+)-(.*)$/i);\n    if (m) return location.protocol + '//p8080-' + m[1] + '-' + m[2];\n    return location.protocol + '//' + h + ':8080';\n  }\n  function boot(){\n    var img = document.getElementById('lv-img');\n    var ph  = document.getElementById('lv-ph');\n    var bg  = document.getElementById('lv-badge');\n    var btn = document.getElementById('lv-reload');\n    if (!img) return setTimeout(boot, 100);\n    function load(){\n      ph.style.display='block';\n      img.style.display='none';\n      ph.textContent='connecting to thermal analyzer…';\n      bg.className='badge';\n      bg.innerHTML='<span class=\"pulse\"></span>LIVE';\n      img.onload  = function(){ ph.style.display='none'; img.style.display='block'; };\n      img.onerror = function(){ ph.style.display='block'; ph.textContent='stream unreachable — is the operator console running?'; img.style.display='none'; bg.className='badge off'; bg.innerHTML='<span class=\"pulse\"></span>OFFLINE'; };\n      img.src = deriveBase() + '/stream.mjpg?ts=' + Date.now();\n    }\n    btn.onclick = load;\n    load();\n  }\n  setTimeout(boot, 0);\n})();\n</script>",
