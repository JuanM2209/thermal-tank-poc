  {
    "id": "tpl-tank-cards",
    "type": "ui_template",
    "z": "thermal-tab",
    "group": "dash-group-tanks",
    "name": "Tank KPI sidebar",
    "order": 1,
    "width": 10,
    "height": 9,
    "format": "<style>\n.tg{display:flex;flex-direction:column;gap:10px;padding:6px;height:100%;overflow-y:auto}\n.tc{background:#1c222b;border:1px solid #2a3240;border-radius:12px;padding:12px;color:#e6e6e6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;transition:border-color .2s;flex:0 0 auto}\n.tc.hi{border-color:#22c55e}\n.tc.lo{border-color:#f59e0b}\n.tc.al{border-color:#ef4444;box-shadow:0 0 0 1px #ef4444 inset}\n.tc h4{margin:0 0 8px 0;font-size:13px;display:flex;justify-content:space-between;align-items:center;gap:8px}\n.tc h4 .nm{font-weight:700;letter-spacing:-.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n.tc h4 .med{font-size:10px;padding:2px 8px;border-radius:10px;text-transform:uppercase;letter-spacing:.04em;font-weight:700;background:#1e293b;color:#94a3b8;flex:0 0 auto}\n.tc h4 .med.water{background:#082f49;color:#38bdf8}\n.tc h4 .med.oil{background:#3b1d09;color:#fb923c}\n.tc .pri{font-size:28px;font-weight:700;letter-spacing:-0.03em;line-height:1}\n.tc .pri.hi{color:#4ade80}\n.tc .pri.lo{color:#fbbf24}\n.tc .pri.al{color:#f87171}\n.tc .sub{font-size:10px;color:#94a3b8;margin-top:3px;font-family:monospace}\n.tc .bar{height:5px;background:#0f1419;border-radius:3px;overflow:hidden;margin:8px 0 4px 0}\n.tc .bar .fill{height:100%;background:linear-gradient(90deg,#22c55e,#84cc16);transition:width .3s}\n.tc .row{display:flex;justify-content:space-between;font-size:10px;color:#9aa4b2;margin-top:2px;font-family:monospace}\n.tc .row .k{color:#6b7280}\n.tc .rate{display:flex;align-items:baseline;gap:6px;margin-top:8px;padding-top:8px;border-top:1px solid #1f2937;font-size:11px}\n.tc .rate .v{font-weight:700;font-size:13px}\n.tc .rate .v.up{color:#4ade80}\n.tc .rate .v.dn{color:#fbbf24}\n.tc .rate .v.st{color:#94a3b8}\n.tc .chip{display:inline-block;padding:1px 6px;border-radius:10px;font-size:9px;background:#0f1419;color:#9aa4b2;font-family:monospace}\n.tc .chip.hi{background:#052e16;color:#4ade80}\n.tc .chip.lo{background:#2a1f00;color:#fbbf24}\n.empty{padding:30px;text-align:center;color:#64748b;font-family:sans-serif;font-size:12px}\n</style>\n<div class=\"tg\" ng-if=\"msg.payload && msg.payload.tanks && msg.payload.tanks.length\">\n  <div class=\"tc\"\n       ng-repeat=\"t in msg.payload.tanks track by (t.id || t.name || $index)\"\n       ng-class=\"{ hi: t.confidence==='high' && t.level_pct>=20 && t.level_pct<=90, lo: t.confidence!=='high', al: t.level_pct<20 || t.level_pct>90 }\">\n    <h4>\n      <span class=\"nm\">{{t.name || t.id}}</span>\n      <span class=\"med\" ng-class=\"t.medium\">{{t.medium || 'unknown'}}</span>\n    </h4>\n    <div class=\"pri\" ng-class=\"{ hi: t.confidence==='high' && t.level_pct>=20 && t.level_pct<=90, lo: t.confidence!=='high', al: t.level_pct<20 || t.level_pct>90 }\">\n      <span ng-if=\"t.reading && t.reading.level_ft !== undefined && t.reading.level_ft !== null\">{{t.reading.level_ft | number:2}} ft</span>\n      <span ng-if=\"!t.reading || t.reading.level_ft === undefined || t.reading.level_ft === null\">{{t.level_pct | number:1}}%</span>\n    </div>\n    <div class=\"sub\" ng-if=\"t.geometry && t.geometry.height_ft\">of {{t.geometry.height_ft | number:1}} ft &middot; ⌀ {{t.geometry.diameter_ft | number:1}} ft</div>\n    <div class=\"bar\"><div class=\"fill\" ng-style=\"{ width: (t.level_pct || 0) + '%' }\"></div></div>\n    <div class=\"row\"><span class=\"k\">level %</span><span>{{t.level_pct | number:1}}%</span></div>\n    <div class=\"row\" ng-if=\"t.reading && t.reading.volume_bbl !== undefined && t.reading.volume_bbl !== null\"><span class=\"k\">volume</span><span>{{t.reading.volume_bbl | number:0}} bbl</span></div>\n    <div class=\"row\" ng-if=\"t.reading && t.reading.ullage_ft !== undefined && t.reading.ullage_ft !== null\"><span class=\"k\">ullage</span><span>{{t.reading.ullage_ft | number:2}} ft</span></div>\n    <div class=\"row\"><span class=\"k\">temp avg</span><span>{{t.temp_avg | number:1}}°C</span></div>\n    <div class=\"row\"><span class=\"k\">confidence</span><span class=\"chip\" ng-class=\"{ hi: t.confidence==='high', lo: t.confidence!=='high' }\">{{t.confidence}}<span ng-if=\"t.medium_confidence !== undefined\"> &middot; m{{t.medium_confidence | number:2}}</span></span></div>\n    <div class=\"rate\" ng-if=\"t.reading && t.reading.fill_rate_bbl_h !== undefined && t.reading.fill_rate_bbl_h !== null\">\n      <span class=\"v\" ng-class=\"{ up: t.reading.fill_rate_bbl_h > 0.5, dn: t.reading.fill_rate_bbl_h < -0.5, st: t.reading.fill_rate_bbl_h >= -0.5 && t.reading.fill_rate_bbl_h <= 0.5 }\">\n        <span ng-if=\"t.reading.fill_rate_bbl_h > 0.5\">▲</span><span ng-if=\"t.reading.fill_rate_bbl_h < -0.5\">▼</span><span ng-if=\"t.reading.fill_rate_bbl_h >= -0.5 && t.reading.fill_rate_bbl_h <= 0.5\">─</span>\n        {{t.reading.fill_rate_bbl_h | number:1}} bbl/h\n      </span>\n    </div>\n  </div>\n</div>\n<div class=\"empty\" ng-if=\"!msg.payload || !msg.payload.tanks || !msg.payload.tanks.length\">\n  Waiting for first payload&hellip;\n</div>",
