  {
    "id": "inject-startup",
    "type": "inject",
    "z": "thermal-tab",
    "name": "on start",
    "props": [{ "p": "payload" }],
    "repeat": "",
    "crontab": "",
    "once": true,
    "onceDelay": 0.1,
